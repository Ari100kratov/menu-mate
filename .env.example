# MenuMate Docker Compose / Portainer stack example.
# Скопируйте файл в `.env` для локального Docker Compose или задайте эти переменные
# в Portainer: Stacks -> Environment variables.
#
# В продакшне обязательно замените все значения `change-me-*`.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Для хостинга оставляйте Production. Development включает dev-only поведение.
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Адрес и порт фронтенда на Linux-хосте. 0.0.0.0 подходит, когда reverse proxy
# работает в отдельном контейнере или на другой машине. Для proxy на самом хосте
# безопаснее использовать 127.0.0.1.
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=80

# Диагностический порт API всегда привязан к 127.0.0.1. Фронтенд обращается к API через /api.
API_PORT=5000

# OpenAPI и Scalar в Production по умолчанию отключены.
EXPOSE_API_DOCS=false

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_DB=menumate
POSTGRES_USER=menumate
POSTGRES_PASSWORD=change-me-postgres-password

# Диагностический порт БД привязан к 127.0.0.1 и недоступен извне Linux-хоста.
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

JWT_ISSUER=MenuMate
JWT_AUDIENCE=MenuMate

# Минимум 32 байта. Используйте случайную длинную строку и не меняйте ее без
# необходимости, иначе текущие access tokens перестанут проходить проверку.
JWT_SECRET=change-me-jwt-secret-at-least-32-bytes-long

# Время жизни access token в минутах.
JWT_EXPIRATION_IN_MINUTES=60

# -----------------------------------------------------------------------------
# MinIO / S3-compatible object storage
# -----------------------------------------------------------------------------

MINIO_ROOT_USER=menumate-minio
MINIO_ROOT_PASSWORD=change-me-minio-root-password

# Локальные порты MinIO API и консоли. Они привязаны только к 127.0.0.1 и недоступны извне.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Публичный адрес фронтенда без схемы. Именно он попадёт в подписанные ссылки на изображения:
# Nginx проксирует /images/* и /imports/* во внутренний MinIO. Для production: menu.example.com.
# Если WEB_PORT не равен 80, укажите его здесь, например localhost:8080.
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_USE_SSL=false

# Домены frontend/API, с которых браузер может обращаться к MinIO.
# Для Portainer замените на ваши публичные адреса, например:
# https://menu.example.com,https://api.menu.example.com
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost,http://localhost:5173,http://localhost:5000

MINIO_IMAGES_BUCKET=images
MINIO_IMPORTS_BUCKET=imports

# -----------------------------------------------------------------------------
# Aspire Dashboard
# -----------------------------------------------------------------------------

# Публичный HTTPS URL отдельного домена Dashboard.
ASPIRE_DASHBOARD_PUBLIC_URL=https://aspire.example.com

# Порт UI на Linux-хосте. OTLP-порт наружу не публикуется.
# Используйте 127.0.0.1, если reverse proxy работает прямо на хосте. Для proxy
# в отдельном контейнере оставьте 0.0.0.0 и ограничьте порт firewall-ом.
ASPIRE_DASHBOARD_BIND_ADDRESS=0.0.0.0
ASPIRE_DASHBOARD_PORT=18888

# Два разных случайных секрета. Удобный формат — 64 hex-символа без пробелов и знаков '='.
ASPIRE_DASHBOARD_BROWSER_TOKEN=change-me-dashboard-browser-token-64-hex-characters
ASPIRE_DASHBOARD_OTLP_API_KEY=change-me-dashboard-otlp-api-key-64-hex-characters

# Dashboard хранит телеметрию только в памяти. Эти значения ограничивают её объём.
ASPIRE_DASHBOARD_MEMORY_LIMIT=512m
ASPIRE_DASHBOARD_MAX_LOG_COUNT=10000
ASPIRE_DASHBOARD_MAX_TRACE_COUNT=10000
ASPIRE_DASHBOARD_MAX_METRICS_COUNT=50000

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# Общий ключ распознавания рецептов и генерации обложек. Для AITunnel укажите ключ AITunnel и OPENAI_BASE_URL ниже.
OPENAI_API_KEY=
# Оставьте пустым для api.openai.com. Для AITunnel: https://api.aitunnel.ru/v1/
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# -----------------------------------------------------------------------------
# Recipe import drafts cleanup
# -----------------------------------------------------------------------------

RECIPE_IMPORT_DRAFT_RETENTION_DAYS=7
RECIPE_IMPORT_CLEANUP_INTERVAL_MINUTES=60
